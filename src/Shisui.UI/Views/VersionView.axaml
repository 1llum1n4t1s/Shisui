<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Shisui.UI.ViewModels"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             x:Class="Shisui.UI.Views.VersionView"
             x:DataType="vm:VersionViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="8,0">
      <TextBlock Classes="h1" Text="バージョン情報" />

      <primitives:HeaderedContentControl Header="Shisui">
        <StackPanel Spacing="12">
          <StackPanel Orientation="Horizontal" Spacing="16">
            <Image Width="56" Height="56" VerticalAlignment="Center"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   Source="avares://Shisui.UI/icon/app.ico" />
            <StackPanel VerticalAlignment="Center" Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Shisui" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="止水" FontSize="16" VerticalAlignment="Center" Foreground="{DynamicResource Brush.FG2}" />
              </StackPanel>
              <TextBlock Text="ネットワークを凪いだ状態へ整えるツール" Classes="caption" />
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                <TextBlock Text="バージョン:" Classes="caption" />
                <TextBlock Text="{Binding VersionText}" Classes="caption" />
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="更新を確認" Command="{Binding CheckForUpdateCommand}" IsEnabled="{Binding !IsChecking}" />
            <Button Content="更新をダウンロードして再起動" Command="{Binding DownloadAndApplyCommand}"
                    Classes="accent" IsVisible="{Binding IsUpdateReady}" IsEnabled="{Binding !IsChecking}" />
          </StackPanel>
          <TextBlock Text="{Binding UpdateStatusText}" Classes="caption" TextWrapping="Wrap" />

          <CheckBox Content="起動時に自動で更新を確認する" IsChecked="{Binding CheckForUpdatesOnStartup}" />
        </StackPanel>
      </primitives:HeaderedContentControl>

      <primitives:HeaderedContentControl Header="フォルダ">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="ログフォルダを開く" Command="{Binding OpenLogsFolderCommand}" />
          <Button Content="設定フォルダを開く" Command="{Binding OpenSettingsFolderCommand}" />
        </StackPanel>
      </primitives:HeaderedContentControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
