<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Shisui.UI.ViewModels"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             x:Class="Shisui.UI.Views.MaintenanceView"
             x:DataType="vm:MaintenanceViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="8,0,8,12">
      <TextBlock Classes="h1" Text="メンテナンス" />
      <TextBlock Classes="caption" TextWrapping="Wrap" Margin="4,0,0,12"
                 Text="赤いボタンのコマンドは既存の設定を初期化するなど影響が大きいものです。" />

      <ItemsControl ItemsSource="{Binding Categories}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:MaintenanceCategoryGroup">
            <primitives:HeaderedContentControl Header="{Binding Name}">
              <StackPanel Spacing="6">
                <Button Content="{Binding BatchLabel}" Command="{Binding RunAllCommand}"
                        IsVisible="{Binding SupportsBatch}" IsEnabled="{Binding !IsRunningAll}"
                        HorizontalAlignment="Left" Margin="0,0,0,2" Classes="accent" />
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MaintenanceCommandItemViewModel">
                      <Grid ColumnDefinitions="*,Auto" Margin="0,6">
                        <StackPanel Grid.Column="0" Spacing="1" Margin="0,0,12,0">
                          <TextBlock Text="{Binding Definition.Label}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Definition.Description}" Classes="caption" TextWrapping="Wrap" />
                          <TextBlock Text="※ 再起動後に有効になります" FontSize="12" Foreground="#FF3B30" IsVisible="{Binding Definition.RequiresReboot}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="実行" Command="{Binding RunCommand}"
                                Classes.danger="{Binding Definition.IsDestructive}" VerticalAlignment="Center" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </primitives:HeaderedContentControl>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="{Binding StatusText}" Classes="caption" Margin="4,0,0,0" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
