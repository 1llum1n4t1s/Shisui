<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Shisui.UI.ViewModels"
             xmlns:models="using:Shisui.Core.Models"
             xmlns:conv="using:Shisui.UI.Converters"
             xmlns:acv="using:Avalonia.Data.Converters"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             x:Class="Shisui.UI.Views.DnsSettingsView"
             x:DataType="vm:DnsSettingsViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="8,0">
      <TextBlock Classes="h1" Text="DNS 設定" />

      <primitives:HeaderedContentControl Header="ネットワークアダプタ">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Adapters}"
                      SelectedItem="{Binding SelectedAdapter}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="models:NetworkAdapterInfo">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding DisplayName}" />
                    <TextBlock Text="(無効)" Classes="caption" IsVisible="{Binding !IsUp}" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="1" Content="一覧を更新" Command="{Binding LoadAdaptersCommand}" Margin="8,0,0,0" />
          </Grid>

          <StackPanel IsVisible="{Binding SelectedAdapter, Converter={x:Static acv:ObjectConverters.IsNotNull}}" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="現在の IPv4 DNS:" Classes="caption" />
              <TextBlock Text="{Binding SelectedAdapter.CurrentIPv4Dns, Converter={x:Static conv:JoinStringsConverter.Instance}}" Classes="caption" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="現在の IPv6 DNS:" Classes="caption" />
              <TextBlock Text="{Binding SelectedAdapter.CurrentIPv6Dns, Converter={x:Static conv:JoinStringsConverter.Instance}}" Classes="caption" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="MAC アドレス:" Classes="caption" />
              <TextBlock Text="{Binding AdapterDetails.MacAddress, TargetNullValue='取得できません'}" Classes="caption" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="リンク速度:" Classes="caption" />
              <TextBlock Text="{Binding AdapterDetails.LinkSpeedText, TargetNullValue='取得できません'}" Classes="caption" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </primitives:HeaderedContentControl>

      <primitives:HeaderedContentControl Header="DNS プロバイダ">
        <StackPanel Spacing="8">
          <ComboBox ItemsSource="{Binding Presets}"
                    SelectedItem="{Binding SelectedPreset}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="models:DnsProviderPreset">
                <StackPanel Spacing="1" Margin="0,2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Description}" Classes="caption" />
                </StackPanel>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <StackPanel IsVisible="{Binding IsCustomPresetSelected}" Spacing="8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <StackPanel Width="220">
                <TextBlock Text="IPv4 プライマリ" Classes="caption" />
                <TextBox Text="{Binding CustomIpv4Primary}" PlaceholderText="例: 1.1.1.1" />
              </StackPanel>
              <StackPanel Width="220">
                <TextBlock Text="IPv4 セカンダリ" Classes="caption" />
                <TextBox Text="{Binding CustomIpv4Secondary}" PlaceholderText="例: 1.0.0.1" />
              </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
              <StackPanel Width="220">
                <TextBlock Text="IPv6 プライマリ" Classes="caption" />
                <TextBox Text="{Binding CustomIpv6Primary}" PlaceholderText="例: 2606:4700:4700::1111" />
              </StackPanel>
              <StackPanel Width="220">
                <TextBlock Text="IPv6 セカンダリ" Classes="caption" />
                <TextBox Text="{Binding CustomIpv6Secondary}" PlaceholderText="例: 2606:4700:4700::1001" />
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <StackPanel IsVisible="{Binding IsDohAvailable}" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <CheckBox Content="DNS over HTTPS (DoH) を有効にする" IsChecked="{Binding UseDoh}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding DohStateText}" Classes="caption" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsDotAvailable}" Spacing="2" Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <CheckBox Content="DNS over TLS (DoT) を有効にする" IsChecked="{Binding UseDot}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Classes="caption" TextWrapping="Wrap"
                       Text="※ Windows に DoT の登録状況を読み取る手段が無いため、このチェックボックスは実際の OS 状態を反映しません (適用のたびに有効化/無効化コマンドを実行するだけで、次回起動時は未チェックに戻ります)。" />
          </StackPanel>

          <TextBlock IsVisible="{Binding ShowDohDotInteractionNote}" Classes="caption" TextWrapping="Wrap" Margin="0,4,0,0"
                     Text="ℹ 両方チェックしても構いません。同じ IP アドレスに対する DoH と DoT の登録は互いに上書きせず共存し、Windows はどちらか一方だけを優先するのではなく両方を実際に使用します (実機のパケットキャプチャで確認済み)。ただし暗号化そのものの効果は片方だけで十分得られるため、両方有効にする実利は大きくありません。" />

          <TextBlock IsVisible="{Binding ShowDohDotInteractionNote}" Classes="caption" TextWrapping="Wrap" Margin="0,2,0,0"
                     Text="ℹ 速度について: 「DoT の方が仕組み上軽量で速い」とよく言われますが、実機での応答時間計測 (平文DNS / DoH / DoT を切り替えて比較) では逆に DoH の方がわずかに速く、ばらつきも小さい結果になりました。DoH は接続を張ったまま使い回すのに対し DoT は数秒おきに接続を張り直す挙動のためと見られます。オンライン対戦ゲーム等でレイテンシのブレを避けたい場合、暗号化を使うなら DoT より DoH を選ぶことを推奨します。ただし差は数 ms 程度で、そもそも DNS の名前解決は対戦中の通信そのものには関与しないため、体感できるほどの影響は通常ありません。" />
        </StackPanel>
      </primitives:HeaderedContentControl>

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,4">
        <Button Content="適用" Command="{Binding ApplyCommand}" IsEnabled="{Binding !IsBusy}" />
        <Button Content="自動取得 (DHCP) に戻す" Command="{Binding ResetToAutomaticCommand}" IsEnabled="{Binding !IsBusy}" />
        <Button Content="DNS キャッシュをクリア" Command="{Binding FlushDnsCacheCommand}" IsEnabled="{Binding !IsBusy}" />
        <Button Content="疎通テスト" Command="{Binding PingSelectedDnsCommand}" IsEnabled="{Binding !IsPinging}" />
      </StackPanel>
      <TextBlock Text="{Binding StatusText}" Classes="caption" Margin="4,4,0,0" />
      <TextBlock Text="{Binding PingStatusText}" Classes="caption" Margin="4,2,0,12" />

      <primitives:HeaderedContentControl Header="不要になったネットワークデバイスの掃除" IsVisible="{Binding IsWindows}">
        <StackPanel Spacing="10">
          <TextBlock Classes="caption" TextWrapping="Wrap"
                     Text="取り外した USB アダプタや、アンインストールした VPN クライアントなど、現在は接続されていないのにレジストリ上の登録が残っているネットワークデバイスを削除します。「Microsoft 製」の項目は VPN 機能等で使う Windows 標準の仮想デバイスであることが多く、通常は削除不要です。削除後に該当デバイスを再度使う場合、ドライバーの再インストールが必要になることがあります。" />

          <Button Content="一覧を更新" Command="{Binding LoadGhostAdaptersCommand}" IsEnabled="{Binding !IsGhostAdaptersBusy}" HorizontalAlignment="Left" />

          <ItemsControl ItemsSource="{Binding GhostAdapters}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:GhostAdapterItemViewModel">
                <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="0,8">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="1" Margin="0,0,12,0">
                      <TextBlock Text="{Binding Info.Description}" FontWeight="SemiBold" />
                      <TextBlock Classes="caption" Text="{Binding Info.Manufacturer, StringFormat='製造元: {0}'}" />
                      <TextBlock Text="⚠ Microsoft 標準の仮想デバイスです。通常は削除不要です。" FontSize="12" Foreground="#FF9F0A"
                                 IsVisible="{Binding Info.IsLikelyMicrosoftVirtualDevice}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="削除" Command="{Binding RemoveCommand}" Classes="danger" VerticalAlignment="Center" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{Binding GhostAdaptersStatusText}" Classes="caption" />
        </StackPanel>
      </primitives:HeaderedContentControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
