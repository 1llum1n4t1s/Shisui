<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Shisui.UI.ViewModels"
        xmlns:views="using:Shisui.UI.Views"
        x:Class="Shisui.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Shisui"
        Icon="avares://Shisui.UI/icon/app.ico"
        Width="880" Height="620" MinWidth="760" MinHeight="500"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="32"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="AcrylicBlur"
        WindowStartupLocation="CenterScreen">

  <Panel>
    <!--  ウィンドウ背景：アクリルブラー (Lhamiel と同じ Tahoe 風ガラス質感)  -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
            BackgroundSource="Digger"
            MaterialOpacity="0.85"
            TintColor="{DynamicResource Color.Window}"
            TintOpacity="0.9" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Grid Margin="16,36,16,16" RowDefinitions="*,Auto">
      <!--  ═══ サイドバー + コンテンツ ═══  -->
      <TabControl Grid.Row="0" Classes="sidebar">
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  地球儀アイコン(円+赤道線+子午線)  -->
              <Canvas Width="16" Height="16">
                <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" />
                <Line StartPoint="1,8" EndPoint="15,8"
                      Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" />
                <Ellipse Width="6" Height="14" Canvas.Left="5" Canvas.Top="1"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.2" />
              </Canvas>
              <TextBlock Text="DNS 設定" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:DnsSettingsView DataContext="{Binding DnsSettings}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  パルスアイコン(疎通診断の脈波線)  -->
              <Canvas Width="16" Height="16">
                <Polyline Points="1,8 4,8 6,3 8,13 10,8 15,8"
                          Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.4" />
              </Canvas>
              <TextBlock Text="ネットワーク診断" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:NetworkDiagnosticsView DataContext="{Binding NetworkDiagnostics}" />
        </TabItem>
        <TabItem IsVisible="{Binding IsWindows}">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  ゲージアイコン(円弧+針+軸)  -->
              <Canvas Width="16" Height="16">
                <Path Data="M 2,12.5 A 6,6 0 0 1 14,12.5"
                      Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" StrokeLineCap="Round" />
                <Line StartPoint="8,12.5" EndPoint="10.8,7.5"
                      Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" StrokeLineCap="Round" />
                <Ellipse Width="2.2" Height="2.2" Canvas.Left="6.9" Canvas.Top="11.4"
                         Fill="{DynamicResource Brush.FG1}" />
              </Canvas>
              <TextBlock Text="BBR2 / TCP 調整" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:TcpTuningView DataContext="{Binding TcpTuning}" />
        </TabItem>
        <TabItem IsVisible="{Binding IsWindows}">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  ギアアイコン(ハブ+歯8枚)  -->
              <Canvas Width="16" Height="16">
                <Ellipse Width="8" Height="8" Canvas.Left="4" Canvas.Top="4"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" />
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="0" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="45" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="90" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="135" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="180" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="225" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="270" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle Width="2" Height="3.2" Canvas.Left="7" Canvas.Top="0.8" Fill="{DynamicResource Brush.FG1}">
                  <Rectangle.RenderTransform>
                    <RotateTransform Angle="315" CenterX="1" CenterY="7.2" />
                  </Rectangle.RenderTransform>
                </Rectangle>
              </Canvas>
              <TextBlock Text="メンテナンス" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:MaintenanceView DataContext="{Binding Maintenance}" />
        </TabItem>
        <TabItem>
          <TabItem.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <!--  インフォアイコン(円+i)  -->
              <Canvas Width="16" Height="16">
                <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                         Stroke="{DynamicResource Brush.FG1}" StrokeThickness="1.3" />
                <Ellipse Width="1.6" Height="1.6" Canvas.Left="7.2" Canvas.Top="4.2"
                         Fill="{DynamicResource Brush.FG1}" />
                <Rectangle Width="1.6" Height="5.5" Canvas.Left="7.2" Canvas.Top="6.8"
                           RadiusX="0.8" RadiusY="0.8" Fill="{DynamicResource Brush.FG1}" />
              </Canvas>
              <TextBlock Text="バージョン" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </TabItem.Header>
          <views:VersionView DataContext="{Binding Version}" />
        </TabItem>
      </TabControl>

      <!--  ═══ 実行ログ (Lhamiel のガラスカードと同じ質感)  ═══  -->
      <Border
          Grid.Row="1"
          Margin="0,12,0,0"
          Padding="12"
          Background="{DynamicResource Brush.Container}"
          BorderBrush="{DynamicResource Brush.Border}"
          BorderThickness="1"
          CornerRadius="14">
        <Grid RowDefinitions="Auto,*" MaxHeight="180">
          <TextBlock Grid.Row="0" Text="実行ログ" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource Brush.FG2}" Margin="0,0,0,8" />
          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding LogEntries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:CommandLogEntry">
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" FontFamily="Consolas,Menlo,monospace"
                               FontSize="12" Foreground="{DynamicResource Brush.FG2}" />
                    <TextBlock Text="OK" Foreground="#34C759" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                               FontWeight="SemiBold" IsVisible="{Binding Success}" />
                    <TextBlock Text="NG" Foreground="#FF3B30" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                               FontWeight="SemiBold" IsVisible="{Binding !Success}" />
                    <TextBlock Text="{Binding CommandLine}" FontFamily="Consolas,Menlo,monospace" FontSize="12"
                               Foreground="{DynamicResource Brush.FG1}" TextWrapping="NoWrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>
  </Panel>
</Window>
