<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Shisui.UI.App"
             RequestedThemeVariant="Default">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Resources/Themes.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!--  ═══════════════════════════════════════════════════════════  -->
    <!--  macOS Tahoe 風グローバルスタイル (Lhamiel と共通デザイン言語)  -->
    <!--  ═══════════════════════════════════════════════════════════  -->

    <!--  全ウィンドウ共通フォント：CJK フォールバック付き  -->
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Yu Gothic UI, Segoe UI, Microsoft YaHei, Malgun Gothic, Noto Sans CJK, sans-serif" />
    </Style>

    <!--  サイドバー：Tahoe 風カスタムテンプレート  -->
    <Style Selector="TabControl.sidebar">
      <Setter Property="TabStripPlacement" Value="Left" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <ControlTemplate TargetType="TabControl">
          <Grid ColumnDefinitions="180,*">
            <!--  浮遊サイドバーパネル  -->
            <Border
                Grid.Column="0"
                Margin="0,0,12,12"
                Padding="6"
                Background="{DynamicResource Brush.Container}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                BoxShadow="0 8 24 0 #18000000, 0 2 6 0 #10000000, inset 0 1 0 0 #30FFFFFF"
                CornerRadius="14">
              <ItemsPresenter Name="PART_ItemsPresenter">
                <ItemsPresenter.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel HorizontalAlignment="Stretch" />
                  </ItemsPanelTemplate>
                </ItemsPresenter.ItemsPanel>
              </ItemsPresenter>
            </Border>
            <!--  コンテンツエリア  -->
            <ContentPresenter
                Name="PART_SelectedContentHost"
                Grid.Column="1"
                Margin="0"
                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                Content="{TemplateBinding SelectedContent}"
                ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <!--  サイドバー タブ項目：デフォルト  -->
    <Style Selector="TabControl.sidebar &gt; TabItem">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.FG1}" />
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!--  サイドバー タブ項目：テキスト省略  -->
    <Style Selector="TabControl.sidebar &gt; TabItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!--  サイドバー タブ項目：角丸ベース (FluentTheme のボーダーインジケータを無効化)  -->
    <Style Selector="TabControl.sidebar &gt; TabItem /template/ Border#PART_LayoutRoot">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="TabControl.sidebar &gt; TabItem /template/ Border#PART_SelectedPipe">
      <Setter Property="IsVisible" Value="False" />
    </Style>

    <!--  サイドバー タブ項目：ホバー  -->
    <Style Selector="TabControl.sidebar &gt; TabItem:pointerover /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource Brush.SidebarHover}" />
    </Style>

    <!--  サイドバー タブ項目：選択中  -->
    <Style Selector="TabControl.sidebar &gt; TabItem:selected">
      <Setter Property="Foreground" Value="{DynamicResource Brush.FG1}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,1" />
      <Setter Property="MinHeight" Value="28" />
    </Style>
    <Style Selector="TabControl.sidebar &gt; TabItem:selected /template/ Border#PART_LayoutRoot">
      <Setter Property="Background" Value="{DynamicResource Brush.SidebarSelected}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!--  ボタン：Tahoe の大きな角丸 + 十分なパディング  -->
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  危険な操作用ボタン (Lhamiel には無いが同じ角丸・余白規則を継承)  -->
    <Style Selector="Button.danger">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#FF3B30" />
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#E6352B" />
    </Style>

    <!--  推奨・強調操作用ボタン (「おまかせ高速化設定」等、初心者に一番目立ってほしい操作)  -->
    <Style Selector="Button.accent">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
    </Style>

    <!--  ComboBox：Tahoe 風の角丸  -->
    <Style Selector="ComboBox">
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!--  TextBox：Tahoe 風の角丸  -->
    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <!--  CheckBox：角丸を強調  -->
    <Style Selector="CheckBox /template/ Border#NormalRectangle">
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!--  HeaderedContentControl：Tahoe 風ガラスパネル (設定カードの基本単位)  -->
    <Style Selector="HeaderedContentControl">
      <Setter Property="Template">
        <ControlTemplate>
          <Border
              Margin="0,0,0,12"
              Padding="16"
              Background="{DynamicResource Brush.Container}"
              BorderBrush="{DynamicResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="14">
            <StackPanel>
              <TextBlock
                  Margin="0,0,0,10"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="{DynamicResource Brush.FG2}"
                  Text="{TemplateBinding Header}" />
              <ContentPresenter Name="PART_ContentPresenter" Content="{TemplateBinding Content}" />
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <!--  ページ見出し (各タブ先頭の大見出し、Lhamiel の各設定タブと同じ規則)  -->
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="4,0,0,12" />
    </Style>

    <!--  補足テキスト  -->
    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.FG2}" />
    </Style>

    <!--  カード (HeaderedContentControl を使わない単純な区画用)  -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource Brush.Container}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
  </Application.Styles>

</Application>
